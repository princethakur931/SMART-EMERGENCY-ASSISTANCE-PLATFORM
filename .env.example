# Server Configuration
PORT=3000

# MongoDB Connection String (Atlas)
# Get your URI from: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>

# Google Maps API Key
# Get your key from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AI Agent Key — used to generate smart replies for incoming emergency SMS
AI_AGENT_KEY=your_ai_agent_key_here

# ─── Twilio Webhook URLs ──────────────────────────────────────────────────────
# Twilio Console mein set karo:
#   console.twilio.com → Phone Numbers → <your_number> → Messaging Webhook
#
# 🌐 PRODUCTION (Render) — yahi set karo Twilio Console mein:
TWILIO_WEBHOOK_URL=https://<your-render-app>.onrender.com/sms/incoming
#
# 💻 LOCAL TESTING — Dono steps karne hain:
#
#   STEP 1 — Pehli baar sirf (Ngrok install karo):
#     Download: https://ngrok.com/download
#     Account:  https://dashboard.ngrok.com/signup
#     Token:    https://dashboard.ngrok.com/get-started/your-authtoken
#     Terminal: ngrok config add-authtoken <TUMHARA_TOKEN>
#     Free domain: https://dashboard.ngrok.com/domains → New Domain
#
#   STEP 2 — Har baar local test karne ke liye (2 terminal open karo):
#     Terminal 1:  node server.js
#     Terminal 2:  ngrok http --domain=<your-ngrok-domain> 3000
#
#   STEP 3 — Twilio Console mein webhook change karo:
#     console.twilio.com → Phone Numbers → <your_number>
#     → Messaging Configuration → Webhook URL:
#     https://<your-ngrok-domain>/sms/incoming
#
#   STEP 4 — Browser mein open karo:
#     http://localhost:3000
#
#   Testing khatam hone ke baad Twilio Console mein Production URL wapas set karo
#
NGROK_DOMAIN=https://your-ngrok-domain.ngrok-free.dev
TWILIO_WEBHOOK_URL_LOCAL=https://your-ngrok-domain.ngrok-free.dev/sms/incoming

# Twilio SMS (for Emergency Contact SOS alerts)
# Get your credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
